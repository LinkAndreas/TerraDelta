# Copy this file to .env.local and fill in your key(s).
# Keys can also be entered in the app UI (per browser); these env vars are the
# fallback used when no key is provided in the UI.

ANTHROPIC_API_KEY=sk-ant-...

# For the Google Gemini provider (either name works):
# GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...
