# TerraDelta environment variables — ALL OPTIONAL.
#
# The app is designed to work with NO server-side secrets: each user enters
# their own API key in the in-app settings (⚙), stored only in their browser.
#
# Set these only if you want a server-side fallback key (e.g. a private/internal
# deployment). Copy this file to `.env.local` (local dev) or pass them as
# container environment variables (Docker / Hostinger).

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
